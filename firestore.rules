rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(orgId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function getMember(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isAdmin(orgId) {
      return isMember(orgId) && getMember(orgId).role == 'admin';
    }

    function isModerator(orgId) {
      return isMember(orgId) && getMember(orgId).role == 'moderator';
    }

    function isAdminOrMod(orgId) {
      return isMember(orgId) && getMember(orgId).role in ['admin', 'moderator'];
    }

    // ─── Users ───────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Own doc: full update.
      // Other user's doc: only memberships + isChild may be changed
      // (used by approveChildInvite, _processPendingInvitations).
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['memberships', 'isChild'])
      );
    }

    // ─── Organizations ───────────────────────────────────────────────────────

    match /organizations/{orgId} {
      // Single doc read: members OR users processing a pending invitation for this org
      allow get: if isMember(orgId) || isSignedIn();
      // List/query (e.g. watchMyOrganizations): checked per doc via memberUids array
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberUids;
      // Children (isChild == true) may not create organizations.
      // Use .get('isChild', false) to safely handle missing field.
      allow create: if isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isChild', false) != true;
      // Admin: full update.
      // Members: may only extend memberUids (e.g. guardian approving child).
      // New user processing own invitation: may add only themselves to memberUids.
      allow update: if isAdmin(orgId) ||
        (isMember(orgId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])) ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']) &&
          request.auth.uid in request.resource.data.memberUids &&
          !(request.auth.uid in resource.data.memberUids) &&
          request.resource.data.memberUids.hasAll(resource.data.memberUids));
      allow delete: if isAdmin(orgId);

      // ─── Member suggestions subcollection ────────────────────────────────

      match /memberSuggestions/{suggestionId} {
        // Regular members (not admin/moderator/child) can create suggestions
        allow create: if isSignedIn() && isMember(orgId) &&
          getMember(orgId).role == 'member';

        // Admin and moderators can read, list, and update (approve/reject)
        allow read: if isAdminOrMod(orgId);
        allow list: if isAdminOrMod(orgId);
        allow update: if isAdminOrMod(orgId);
        allow delete: if isAdmin(orgId);
      }

      // ─── Announcements subcollection (Pinnwand) ──────────────────────────

      match /announcements/{announcementId} {
        // All org members can read announcements
        allow read: if isMember(orgId);
        allow list: if isMember(orgId);

        // Only admin and moderators can create, update, delete
        allow create: if isAdminOrMod(orgId);
        allow update: if isAdminOrMod(orgId);
        allow delete: if isAdminOrMod(orgId);
      }

      // ─── Members subcollection ────────────────────────────────────────────

      match /members/{memberId} {
        // Members of the org can read all member docs.
        // Users can also read their own member doc (e.g. when processing an invitation).
        allow read: if isMember(orgId) || (isSignedIn() && memberId == request.auth.uid);

        // Admin creates members via inviteMember(); OR
        // User creates their own member doc (org creation → role=admin, or invitation processing)
        allow create: if isSignedIn() && (
          isAdmin(orgId) ||
          memberId == request.auth.uid
        );

        // Admin: full update.
        // Moderator: can update guardianUids.
        // Guardian: can approve pending child (status pending → active).
        // Member: can update own childAlertInterval / lastChildAlertAt.
        allow update: if isSignedIn() && (
          isAdmin(orgId) ||
          (isModerator(orgId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guardianUids'])) ||
          (isMember(orgId) &&
            request.auth.uid in resource.data.guardianUids &&
            resource.data.status == 'pending' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
            request.resource.data.status == 'active') ||
          (memberId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['childAlertInterval', 'lastChildAlertAt', 'displayName', 'photoUrl', 'notificationsEnabled', 'messageAlertInterval']))
        );

        allow delete: if isAdmin(orgId) || memberId == request.auth.uid;
      }
    }

    // ─── Conversations ───────────────────────────────────────────────────────

    match /conversations/{convId} {
      // Single document read: participant, orgAdmin, canApprove member, or guardian
      allow get: if isSignedIn() && (
        request.auth.uid in resource.data.participantUids ||
        resource.data.orgAdminUid == request.auth.uid ||
        request.auth.uid in resource.data.canApproveUids ||
        request.auth.uid in resource.data.guardianUids
      );

      // Queries: allow if the returned doc includes the caller in one of the uid arrays.
      // Covers: watchOrgConversations, watchAdminConversations, watchPendingRequests,
      //         watchModeratorPendingRequests, watchGuardianPendingRequests,
      //         watchSupervisorConversations, watchGuardianSupervisorConversations,
      //         watchShelteredModeratorConversations
      allow list: if isSignedIn() && (
        request.auth.uid in resource.data.participantUids ||
        resource.data.orgAdminUid == request.auth.uid ||
        request.auth.uid in resource.data.canApproveUids ||
        request.auth.uid in resource.data.guardianUids
      );

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        // Pinning/unpinning: only orgAdmin or canApproveUids (admins/moderators)
        (request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['pinnedMessageId', 'pinnedMessageText']) &&
          (resource.data.orgAdminUid == request.auth.uid ||
           request.auth.uid in resource.data.canApproveUids)) ||
        // All other fields: any participant, orgAdmin, canApprove member, or guardian
        (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['pinnedMessageId', 'pinnedMessageText']) &&
          (request.auth.uid in resource.data.participantUids ||
           resource.data.orgAdminUid == request.auth.uid ||
           request.auth.uid in resource.data.canApproveUids ||
           request.auth.uid in resource.data.guardianUids))
      );

      allow delete: if isSignedIn() && isAdmin(resource.data.orgId);

      // ─── Scheduled Messages subcollection ────────────────────────────────

      match /scheduledMessages/{smId} {
        function convData() {
          return get(/databases/$(database)/documents/conversations/$(convId)).data;
        }
        function canSendInConv() {
          return request.auth.uid in convData().participantUids ||
                 convData().orgAdminUid == request.auth.uid ||
                 request.auth.uid in convData().canApproveUids;
        }
        // Only the sender can read, create and delete their own scheduled messages
        allow read:   if isSignedIn() && request.auth.uid == resource.data.senderUid;
        allow create: if isSignedIn() &&
          canSendInConv() &&
          request.resource.data.senderUid == request.auth.uid;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.senderUid;
      }

      // ─── Polls subcollection ──────────────────────────────────────────────

      match /polls/{pollId} {
        function convSnap() {
          return get(/databases/$(database)/documents/conversations/$(convId)).data;
        }
        function isConvParticipant() {
          return request.auth.uid in convSnap().participantUids ||
                 convSnap().orgAdminUid == request.auth.uid ||
                 request.auth.uid in convSnap().canApproveUids;
        }

        allow read: if isSignedIn() && (
          isConvParticipant() ||
          request.auth.uid in convSnap().guardianUids
        );

        // Any participant can create a poll
        allow create: if isSignedIn() && isConvParticipant() &&
          request.resource.data.createdBy == request.auth.uid;

        // Participants can vote (votes field only); creator/admin can also close
        allow update: if isSignedIn() && (
          (isConvParticipant() &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['votes'])) ||
          (resource.data.createdBy == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['isClosed'])) ||
          convSnap().orgAdminUid == request.auth.uid
        );

        allow delete: if isSignedIn() && (
          resource.data.createdBy == request.auth.uid ||
          convSnap().orgAdminUid == request.auth.uid
        );
      }

      // ─── Messages subcollection ───────────────────────────────────────────

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantUids ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.orgAdminUid == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.canApproveUids ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.guardianUids
        );

        allow create: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantUids ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.canApproveUids ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.orgAdminUid == request.auth.uid
        );

        allow update: if isSignedIn() && (
          request.auth.uid == resource.data.senderUid ||
          isAdminOrMod(get(/databases/$(database)/documents/conversations/$(convId)).data.orgId) ||
          // Reactions: any participant can set/remove their own reaction
          (request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantUids &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
        );

        allow delete: if isSignedIn() &&
          isAdmin(get(/databases/$(database)/documents/conversations/$(convId)).data.orgId);
      }
    }

    // ─── Invitation Lookup ───────────────────────────────────────────────────
    // Dokument-ID = normalisierte E-Mail-Adresse.
    // Enthält die Einladungs-IDs für noch nicht registrierte Nutzer.
    // Kein List-Query nötig – nur direktes GET per eigener E-Mail.

    match /invitationLookup/{email} {
      // Nur der Nutzer mit dieser E-Mail darf lesen
      allow get: if isSignedIn() && email == request.auth.token.email.lower();
      // Admin/Mod darf schreiben (beim Anlegen/Genehmigen einer Einladung)
      allow write: if isSignedIn();
    }

    // ─── Invitations ─────────────────────────────────────────────────────────

    match /invitations/{inviteId} {
      // Admin/Mod reads invitations for their org (e.g. duplicate check);
      // invited user reads by their email (from JWT token — no get() needed);
      // guardians read invites they are listed in.
      allow read: if isSignedIn() && (
        isAdminOrMod(resource.data.orgId) ||
        resource.data.email == request.auth.token.email.lower() ||
        request.auth.uid in resource.data.guardianUids
      );

      // Only admins/mods of the org can create invitations
      allow create: if isSignedIn() && isAdminOrMod(request.resource.data.orgId);

      // Invited user can update (accept/invalid); admin/mod can cancel
      allow update: if isSignedIn() && (
        isAdminOrMod(resource.data.orgId) ||
        resource.data.email == request.auth.token.email.lower() ||
        request.auth.uid in resource.data.guardianUids
      );
    }

    // ─── Reports ─────────────────────────────────────────────────────────────

    match /reports/{reportId} {
      // Any signed-in member of the org can create a report
      allow create: if isSignedIn() && isMember(request.resource.data.orgId);

      // Admin and moderators can read and update (mark reviewed) reports
      allow read: if isSignedIn() && isAdminOrMod(resource.data.orgId);
      allow update: if isSignedIn() && isAdminOrMod(resource.data.orgId);
      allow delete: if isSignedIn() && isAdmin(resource.data.orgId);

      // Listing (for query) — only admin/moderator of the report's org
      allow list: if isSignedIn() && isAdminOrMod(resource.data.orgId);
    }
  }
}
