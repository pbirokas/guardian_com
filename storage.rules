rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile images: owner can read/write, everyone signed-in can read
    match /profileImages/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Chat images — write only if the file name starts with the caller's UID
    match /chatImages/{convId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && fileName.matches(request.auth.uid + '.*')
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Voice messages — write only if the file name starts with the caller's UID
    match /voiceMessages/{convId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && fileName.matches(request.auth.uid + '.*')
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }
  }
}
