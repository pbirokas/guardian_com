rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile images: owner can read/write, everyone signed-in can read
    match /profileImages/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Chat images: any signed-in user can read; only participants can upload
    // (participants check is done client-side; storage rules enforce size/type)
    match /chatImages/{convId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
